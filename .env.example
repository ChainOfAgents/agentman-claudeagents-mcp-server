# agentman-claudeagents-mcp-server — Environment Configuration
# Copy this file to .env and customize for your environment.
#
# MINIMUM REQUIRED: ANTHROPIC_API_KEY (for stdio mode) — everything else
# has sensible defaults. In HTTP mode, the API key comes from the
# Authorization: Bearer header on each request and ANTHROPIC_API_KEY is unused.

# =============================================================================
# Anthropic API Credentials
# =============================================================================

# Your Anthropic API key. Required for stdio mode (local install in
# Claude Desktop / Cursor / etc.). For HTTP mode, leave blank — the key
# comes from the Authorization header on incoming MCP requests.
#
# Generate at: https://console.anthropic.com/settings/keys
# We recommend creating a dedicated key named "claudeagents-mcp" so you
# can revoke it independently.
ANTHROPIC_API_KEY=

# =============================================================================
# Anthropic API Configuration
# =============================================================================

# Base URL for the Anthropic API (rarely needs changing)
SAAS_API_BASE_URL=https://api.anthropic.com

# Anthropic API version header (rarely needs changing)
ANTHROPIC_VERSION=2023-06-01

# Anthropic beta header for Managed Agents.
# Update this when Anthropic releases a new beta version.
ANTHROPIC_BETA=managed-agents-2026-04-01

# Long-running request timeout (default: 30 minutes for streaming tools
# like run_task, wait_for_session_idle, stream_session_events)
API_TIMEOUT_MS=1800000

# Fast read timeout for list/get operations (default: 30 seconds)
API_FAST_TIMEOUT_MS=30000

# =============================================================================
# Server Identity
# =============================================================================

MCP_SERVER_NAME=claudeagents_mcp
MCP_SERVER_VERSION=0.1.0

# The public URL where this server is deployed (used in OAuth metadata
# when running as a hosted HTTP service). Leave blank for local stdio use.
MCP_SERVER_URL=

# =============================================================================
# Network Configuration (HTTP mode only)
# =============================================================================

# Port to listen on (Cloud Run injects PORT automatically)
PORT=8010

# Host to bind to
HOST=0.0.0.0

# Environment: development, staging, production
NODE_ENV=development

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=info

# =============================================================================
# Rate Limiting (HTTP mode only)
# =============================================================================

RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_WRITES=20

# =============================================================================
# OAuth Configuration (HTTP mode only — NOT USED in stdio mode)
# =============================================================================
# Leave blank for the default passthrough mode where the client's Bearer
# token IS the Anthropic API key. OAuth broker mode is not used for this
# MCP server because Anthropic doesn't expose an OAuth flow for API keys.

# OAUTH_ISSUER=
# OAUTH_AUTHORIZATION_ENDPOINT=
# OAUTH_TOKEN_ENDPOINT=
# OAUTH_SCOPES=
# OAUTH_SERVER_ENABLED=false
