{
  "name": "@agentman/claudeagents-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Claude Managed Agents — promptable agent management from any MCP client (claude.ai, Claude Desktop, Cursor, etc.)",
  "type": "module",
  "main": "dist/http-server.js",
  "bin": {
    "claudeagents-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "src/templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http-server.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-managed-agents",
    "anthropic",
    "agentman",
    "agentwatch"
  ],
  "author": "Agentman",
  "license": "MIT",
  "homepage": "https://github.com/agentman/agentman-claudeagents-mcp-server",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentman/agentman-claudeagents-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/agentman/agentman-claudeagents-mcp-server/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
